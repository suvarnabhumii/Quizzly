<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <RelativeLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="30dp">

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            app:tint="#000000"
            android:layout_centerVertical="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buat Kuis"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/headerContainer"
        android:layout_marginTop="30dp">
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#E0E0E0" android:layout_marginEnd="8dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#000000" android:layout_marginEnd="8dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="#E0E0E0"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/dotsIndicator"
        android:layout_above="@id/btnNextStep"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <EditText
                android:id="@+id/etQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="70dp"
                android:hint="Masukan Pertanyaan"
                android:background="@drawable/bg_input_flat"
                android:padding="16dp"
                android:textSize="14sp"
                android:textColor="#000000"
                android:textColorHint="#757575"
                android:gravity="top|start"
                android:layout_marginBottom="20dp"/>

            <include android:id="@+id/layoutAns1" layout="@layout/item_input_answer" />
            <include android:id="@+id/layoutAns2" layout="@layout/item_input_answer" />
            <include android:id="@+id/layoutAns3" layout="@layout/item_input_answer" />
            <include android:id="@+id/layoutAns4" layout="@layout/item_input_answer" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAddOption"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Tambah Pilihan Jawaban"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/bg_input_flat"
                android:textColor="#000000"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveQuestion"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Simpan Pertanyaan"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/bg_button_blue"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnNextStep"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Selanjutnya"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_blue"
        android:layout_alignParentBottom="true"/>

</RelativeLayout>